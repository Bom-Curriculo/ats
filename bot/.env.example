
# RabbitMQ (consumo/publicação de currículos)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=bomcurriculo
RABBITMQ_PASSWORD=bomcurriculo
RABBITMQ_VHOST=/

IA_PROVIDER=auto
IA_PROVIDER_CHAIN=gemini,deepseek,openai,groq,ollama
USAR_IA_PADRAO=true
IA_TASK_PROVIDER_POLICY=classificacao_vaga=rapido,avaliacao_contextual=principal,sugestoes_seguras=principal,fallback=local
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
